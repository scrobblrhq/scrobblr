  "query": "\n        SELECT al.id, al.title, al.mbid, al.image_url, al.release_date,\n               a.name AS \"artist_name!\"\n        FROM albums al\n        JOIN artists a ON a.id = al.artist_id\n        WHERE al.id = $1\n        ",

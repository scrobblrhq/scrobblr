  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, artist_id, album_id, title, title_normalized, mbid,\n               duration_ms, scrobble_count, created_at\n        FROM tracks\n        WHERE title % $1\n        ORDER BY similarity(title, $1) DESC, scrobble_count DESC\n        LIMIT $2\n        ",

  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, name, name_normalized, mbid, image_url, bio,\n               scrobble_count, listener_count, created_at\n        FROM artists\n        WHERE name % $1\n        ORDER BY similarity(name, $1) DESC, scrobble_count DESC\n        LIMIT $2\n        ",

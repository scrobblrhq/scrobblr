# Copy to .env.docker and pass with:  docker compose --env-file .env.docker up -d --build
# These configure the Docker stack (docker-compose.yml). They are SEPARATE from
# the repo's app-level .env used for `cargo run` on the host.

# --- Postgres ---
POSTGRES_USER=scrobblr
POSTGRES_PASSWORD=change-me
POSTGRES_DB=scrobblr

# --- Redis ---
REDIS_PASSWORD=change-me

# --- API ---
# Host port the API is published on (container always listens on 8080).
API_PORT=8080
# Public origin clients reach the API on. Uploaded image URLs are built as
# {PUBLIC_BASE_URL}/uploads/{file} — set this to your real origin in production
# (e.g. https://api.scrobblr.example).
PUBLIC_BASE_URL=http://localhost:8080

# Optional: enables artist bios in metadata enrichment.
# LASTFM_API_KEY=

# Optional: tracing filter (see tracing-subscriber EnvFilter syntax).
# RUST_LOG=info,sqlx=warn,tower_http=warn

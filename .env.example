# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/scrobblr

# Redis
REDIS_URL=redis://127.0.0.1:6379

# API server bind address
BIND_ADDR=0.0.0.0:8080

# Logging (see tracing-subscriber EnvFilter docs)
# App logs live under the crate targets api/worker/db; sqlx=warn hides query
# noise, tower_http=debug shows HTTP request logs.
RUST_LOG=api=debug,worker=debug,db=debug,sqlx=warn,tower_http=debug

# Postgres pool size (optional, default: 20)
# DB_MAX_CONNECTIONS=20

# Last.fm API key (optional — enables artist bios in metadata enrichment)
# LASTFM_API_KEY=

# Spotify connected accounts (optional — enables linking Spotify via OAuth
# so the worker can auto-scrobble from Spotify's official API). Register an
# app at https://developer.spotify.com/dashboard to get these; the redirect
# URI must exactly match one registered there and point at this API's own
# callback route.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/v1/connect/spotify/callback

# Image uploads (avatars, community artist/album art)
# Directory the images are written to (default: ./uploads)
# UPLOAD_DIR=uploads
# External base URL clients reach the API on; stored image URLs are
# {PUBLIC_BASE_URL}/uploads/{file}. Set this to your public origin in prod
# (e.g. https://api.scrobblr.example), or the emulator host for local mobile dev.
PUBLIC_BASE_URL=http://10.0.2.2:8080
